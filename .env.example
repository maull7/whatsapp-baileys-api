# Environment Variables (opsional)
# Copy file ini ke .env dan sesuaikan

PORT=3000
BASE_URL=http://localhost:3000
AUTH_PATH=auth_info

# MySQL (database utama: auth, api_keys, whitelist, daily_limits, incoming_messages)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=whatsapp_baileys_blast
MYSQL_USER=root
MYSQL_PASSWORD=

# Anti-block
DELAY_NOT_IN_CONTACTS_MS=2000
LIMIT_IN_CONTACTS_PER_DAY=5
LIMIT_NOT_IN_CONTACTS_PER_DAY=3
